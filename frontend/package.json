{
  "name": "stuck-frontend",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:demo": "tsc --noEmit && vite build --mode github-pages-demo",
    "verify:demo-build": "node scripts/verify-demo-build.mjs",
    "start": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:demo": "STUCK_DEMO_E2E=1 playwright test e2e/github-pages-demo.spec.ts"
  },
  "dependencies": {
    "@ibm/plex-mono": "2.5.0",
    "@ibm/plex-sans": "1.1.0",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "@vitest/ui": "4.1.10",
    "happy-dom": "20.11.0",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "allowScripts": {
    "@ibm/plex-mono": false,
    "@ibm/plex-sans": false
  }
}
