# Public HTTPS host served by Caddy.
STUCK_PUBLIC_HOST=localhost

# Production: configure one or both allowlists for this installation.
STUCK_ALLOWED_NGFW_HOSTS=ngfw.example.local
STUCK_ALLOWED_NGFW_CIDRS=

# Optional: fixed NGFW host for the login form and API.
STUCK_DEFAULT_SERVER=

# Isolated lab only. Keep false when STUCK is reachable by other users.
STUCK_ALLOW_ANY_NGFW=false
